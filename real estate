<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Aura Estates Cyprus — Luxury Real Estate</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet"/>
<style>
  :root {
    --charcoal: #1a1a1a;
    --charcoal-mid: #242424;
    --charcoal-soft: #2e2e2e;
    --copper: #b87333;
    --copper-light: #d4935a;
    --copper-pale: #e8c49a;
    --off-white: #f5f0eb;
    --warm-white: #faf7f4;
    --text-muted: #888;
    --text-soft: #bbb;
    --border: rgba(184,115,51,0.2);
    --font-display: 'Cormorant Garamond', Georgia, serif;
    --font-body: 'Jost', sans-serif;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    background: var(--charcoal);
    color: var(--off-white);
    font-family: var(--font-body);
    font-weight: 300;
    overflow-x: hidden;
  }

  /* ── NOISE TEXTURE OVERLAY ── */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 9999;
    opacity: 0.4;
  }

  /* ── NAVIGATION ── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    padding: 0 48px;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: linear-gradient(to bottom, rgba(26,26,26,0.98), rgba(26,26,26,0));
    transition: background 0.4s;
  }
  nav.scrolled { background: rgba(26,26,26,0.97); border-bottom: 1px solid var(--border); }
  .nav-logo {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: var(--off-white);
    text-decoration: none;
  }
  .nav-logo span { color: var(--copper); }
  .nav-links { display: flex; gap: 36px; align-items: center; }
  .nav-links a {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-soft);
    text-decoration: none;
    transition: color 0.25s;
  }
  .nav-links a:hover { color: var(--copper-light); }
  .nav-lang { display: flex; gap: 10px; align-items: center; }
  .lang-btn {
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px 6px;
    transition: color 0.2s;
    font-family: var(--font-body);
  }
  .lang-btn.active, .lang-btn:hover { color: var(--copper); }
  .lang-sep { color: var(--border); font-size: 12px; }
  .nav-cta {
    padding: 10px 24px;
    background: transparent;
    border: 1px solid var(--copper);
    color: var(--copper);
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s;
    text-decoration: none;
  }
  .nav-cta:hover { background: var(--copper); color: var(--charcoal); }

  /* ── HERO ── */
  #hero {
    position: relative;
    height: 100vh;
    min-height: 700px;
    display: flex;
    align-items: flex-end;
    padding: 0 48px 80px;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(160deg, rgba(26,26,26,0) 30%, rgba(26,26,26,0.85) 100%),
      linear-gradient(to bottom, rgba(26,26,26,0.3) 0%, rgba(26,26,26,0.5) 100%);
    z-index: 1;
  }
  .hero-image {
    position: absolute;
    inset: 0;
    background:
      url('https://images.unsplash.com/photo-1570129477492-45c003edd2be?w=1600&q=80') center/cover no-repeat;
    z-index: 0;
    transform: scale(1.05);
    animation: heroZoom 12s ease-out forwards;
  }
  @keyframes heroZoom { to { transform: scale(1); } }
  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 700px;
    animation: heroFadeUp 1.2s ease-out both;
  }
  @keyframes heroFadeUp {
    from { opacity: 0; transform: translateY(40px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .hero-tag {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--copper);
    margin-bottom: 24px;
  }
  .hero-tag::before { content: ''; display: block; width: 32px; height: 1px; background: var(--copper); }
  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(52px, 7vw, 90px);
    font-weight: 300;
    line-height: 1.0;
    letter-spacing: -0.01em;
    margin-bottom: 28px;
    color: var(--warm-white);
  }
  .hero-title em { font-style: italic; color: var(--copper-light); }
  .hero-sub {
    font-size: 13px;
    font-weight: 300;
    letter-spacing: 0.06em;
    color: var(--text-soft);
    margin-bottom: 48px;
    line-height: 1.8;
    max-width: 480px;
  }

  /* Search bar */
  .hero-search {
    display: flex;
    background: rgba(26,26,26,0.9);
    border: 1px solid var(--border);
    backdrop-filter: blur(12px);
    max-width: 620px;
  }
  .search-field {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 14px 20px;
    border-right: 1px solid var(--border);
  }
  .search-field:last-of-type { border-right: none; }
  .search-label {
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--copper);
    margin-bottom: 4px;
  }
  .search-field select, .search-field input {
    background: none;
    border: none;
    outline: none;
    color: var(--off-white);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 300;
    cursor: pointer;
  }
  .search-field select option { background: var(--charcoal); }
  .search-btn {
    padding: 0 28px;
    background: var(--copper);
    border: none;
    color: var(--charcoal);
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.3s;
    white-space: nowrap;
  }
  .search-btn:hover { background: var(--copper-light); }

  /* Scroll indicator */
  .scroll-hint {
    position: absolute;
    bottom: 32px; right: 48px;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-muted);
    animation: heroFadeUp 1.6s ease-out both;
  }
  .scroll-line {
    width: 1px; height: 48px;
    background: linear-gradient(to bottom, var(--copper), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }
  @keyframes scrollPulse { 0%,100%{opacity:0.4} 50%{opacity:1} }

  /* Stats bar */
  .stats-bar {
    position: absolute;
    top: 50%;
    right: 48px;
    transform: translateY(-50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 32px;
    animation: heroFadeUp 1.4s ease-out both;
  }
  .stat-item { text-align: right; }
  .stat-num {
    font-family: var(--font-display);
    font-size: 36px;
    font-weight: 300;
    color: var(--copper-light);
    line-height: 1;
  }
  .stat-lbl { font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--text-muted); margin-top: 4px; }

  /* ── SECTION BASE ── */
  section { padding: 120px 48px; }
  .section-tag {
    display: inline-flex; align-items: center; gap: 10px;
    font-size: 10px; font-weight: 400; letter-spacing: 0.25em;
    text-transform: uppercase; color: var(--copper); margin-bottom: 20px;
  }
  .section-tag::before { content: ''; display: block; width: 24px; height: 1px; background: var(--copper); }
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(36px, 4vw, 56px);
    font-weight: 300;
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--warm-white);
    margin-bottom: 16px;
  }
  .section-title em { font-style: italic; color: var(--copper-light); }
  .section-sub {
    font-size: 13px; font-weight: 300; line-height: 1.9;
    color: var(--text-muted); max-width: 560px;
  }
  .divider {
    width: 100%; height: 1px;
    background: linear-gradient(to right, var(--border), transparent);
    margin: 0;
  }

  /* ── FEATURED PROPERTIES ── */
  #properties { background: var(--charcoal); }
  .props-header {
    display: flex; justify-content: space-between; align-items: flex-end;
    margin-bottom: 60px;
  }
  .props-filter {
    display: flex; gap: 4px;
  }
  .filter-btn {
    padding: 8px 18px;
    background: none;
    border: 1px solid transparent;
    color: var(--text-muted);
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.25s;
  }
  .filter-btn.active, .filter-btn:hover {
    border-color: var(--copper);
    color: var(--copper);
  }
  .props-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
  }
  .prop-card {
    position: relative;
    overflow: hidden;
    cursor: pointer;
    aspect-ratio: 3/4;
  }
  .prop-card.large { grid-row: span 2; aspect-ratio: auto; }
  .prop-card-img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.7s cubic-bezier(0.25,0.46,0.45,0.94);
  }
  .prop-card:hover .prop-card-img { transform: scale(1.06); }
  .prop-card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(26,26,26,0.92) 0%, rgba(26,26,26,0) 55%);
    transition: opacity 0.4s;
  }
  .prop-card-content {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 28px;
    transform: translateY(8px);
    transition: transform 0.4s;
  }
  .prop-card:hover .prop-card-content { transform: translateY(0); }
  .prop-type {
    font-size: 9px; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--copper); margin-bottom: 8px;
  }
  .prop-name {
    font-family: var(--font-display);
    font-size: 22px; font-weight: 400; color: var(--warm-white);
    margin-bottom: 4px;
  }
  .prop-loc { font-size: 11px; color: var(--text-muted); letter-spacing: 0.08em; margin-bottom: 16px; }
  .prop-meta { display: flex; gap: 16px; }
  .prop-meta span { font-size: 11px; color: var(--text-soft); }
  .prop-price {
    font-family: var(--font-display);
    font-size: 24px; font-weight: 300;
    color: var(--copper-light);
    margin-top: 10px;
  }
  .prop-badge {
    position: absolute;
    top: 20px; left: 20px;
    padding: 5px 12px;
    background: var(--copper);
    color: var(--charcoal);
    font-size: 9px; font-weight: 500; letter-spacing: 0.18em; text-transform: uppercase;
  }
  .view-all-wrap { text-align: center; margin-top: 56px; }
  .btn-outline {
    display: inline-flex; align-items: center; gap: 12px;
    padding: 14px 36px;
    border: 1px solid var(--copper);
    color: var(--copper);
    font-family: var(--font-body);
    font-size: 10px; font-weight: 400; letter-spacing: 0.22em; text-transform: uppercase;
    text-decoration: none; cursor: pointer; background: none;
    transition: all 0.3s;
  }
  .btn-outline:hover { background: var(--copper); color: var(--charcoal); }
  .btn-outline::after { content: '→'; font-size: 14px; }

  /* ── SERVICES ── */
  #services { background: var(--charcoal-mid); }
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    margin-top: 72px;
    border: 1px solid var(--border);
  }
  .service-card {
    padding: 52px 40px;
    background: var(--charcoal-mid);
    border: 1px solid transparent;
    transition: all 0.35s;
    position: relative;
    overflow: hidden;
  }
  .service-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(to right, var(--copper), var(--copper-light));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s;
  }
  .service-card:hover { background: var(--charcoal-soft); }
  .service-card:hover::before { transform: scaleX(1); }
  .service-icon {
    font-size: 32px;
    margin-bottom: 28px;
    display: block;
  }
  .service-num {
    font-family: var(--font-display);
    font-size: 72px; font-weight: 300;
    color: rgba(184,115,51,0.08);
    position: absolute;
    top: 20px; right: 28px;
    line-height: 1;
  }
  .service-name {
    font-family: var(--font-display);
    font-size: 28px; font-weight: 400;
    color: var(--warm-white);
    margin-bottom: 16px;
  }
  .service-desc {
    font-size: 13px; font-weight: 300; line-height: 1.8;
    color: var(--text-muted); margin-bottom: 32px;
  }
  .service-list { list-style: none; display: flex; flex-direction: column; gap: 8px; }
  .service-list li {
    font-size: 12px; font-weight: 300; color: var(--text-soft);
    display: flex; align-items: center; gap: 10px;
  }
  .service-list li::before { content: ''; width: 16px; height: 1px; background: var(--copper); flex-shrink: 0; }
  .service-link {
    display: inline-flex; align-items: center; gap: 8px;
    margin-top: 32px;
    font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--copper); cursor: pointer; text-decoration: none;
    transition: gap 0.3s;
  }
  .service-link:hover { gap: 14px; }
  .service-link::after { content: '→'; }

  /* ── ABOUT ── */
  #about {
    background: var(--charcoal);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    padding: 0;
    min-height: 700px;
  }
  .about-image {
    position: relative;
    overflow: hidden;
  }
  .about-image img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }
  .about-image-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to right, rgba(26,26,26,0) 60%, rgba(26,26,26,0.6) 100%);
  }
  .about-content {
    padding: 100px 72px 100px 72px;
    display: flex; flex-direction: column; justify-content: center;
  }
  .about-quote {
    font-family: var(--font-display);
    font-size: 36px; font-weight: 300; font-style: italic;
    line-height: 1.4;
    color: var(--off-white);
    border-left: 2px solid var(--copper);
    padding-left: 28px;
    margin: 32px 0 40px;
  }
  .about-text {
    font-size: 13px; font-weight: 300; line-height: 1.9;
    color: var(--text-muted); margin-bottom: 16px;
  }
  .team-mini {
    display: flex; gap: 16px; margin-top: 48px;
  }
  .team-card {
    flex: 1; padding: 20px;
    border: 1px solid var(--border);
    transition: border-color 0.3s;
  }
  .team-card:hover { border-color: var(--copper); }
  .team-name {
    font-family: var(--font-display);
    font-size: 16px; font-weight: 400;
    color: var(--warm-white); margin-bottom: 4px;
  }
  .team-role { font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--copper); }

  /* ── TESTIMONIALS ── */
  #testimonials { background: var(--charcoal-mid); }
  .testi-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 64px;
  }
  .testi-card {
    padding: 40px 32px;
    border: 1px solid var(--border);
    position: relative;
    transition: border-color 0.3s, transform 0.3s;
  }
  .testi-card:hover { border-color: var(--copper); transform: translateY(-4px); }
  .testi-stars { color: var(--copper); font-size: 14px; letter-spacing: 3px; margin-bottom: 24px; }
  .testi-quote-mark {
    font-family: var(--font-display);
    font-size: 80px; font-weight: 300;
    color: rgba(184,115,51,0.15);
    line-height: 0.7;
    margin-bottom: 8px;
  }
  .testi-text {
    font-family: var(--font-display);
    font-size: 17px; font-weight: 300; font-style: italic;
    line-height: 1.7; color: var(--off-white); margin-bottom: 28px;
  }
  .testi-author { font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--copper); }
  .testi-origin { font-size: 11px; color: var(--text-muted); margin-top: 4px; }

  /* ── CONTACT ── */
  #contact {
    background: var(--charcoal);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
  }
  .contact-info { padding-top: 8px; }
  .contact-detail {
    display: flex; gap: 20px; align-items: flex-start;
    margin-bottom: 28px; padding-bottom: 28px;
    border-bottom: 1px solid var(--border);
  }
  .contact-detail:last-of-type { border-bottom: none; }
  .contact-detail-icon { font-size: 18px; margin-top: 2px; }
  .contact-detail-label {
    font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--copper); margin-bottom: 6px;
  }
  .contact-detail-val { font-size: 14px; font-weight: 300; color: var(--off-white); }
  .form-group { margin-bottom: 20px; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .form-group label {
    display: block;
    font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--copper); margin-bottom: 8px;
  }
  .form-group input, .form-group select, .form-group textarea {
    width: 100%;
    background: var(--charcoal-mid);
    border: 1px solid var(--border);
    color: var(--off-white);
    font-family: var(--font-body);
    font-size: 13px; font-weight: 300;
    padding: 14px 16px;
    outline: none;
    transition: border-color 0.25s;
    resize: none;
  }
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus { border-color: var(--copper); }
  .form-group select option { background: var(--charcoal-mid); }
  .form-submit {
    width: 100%;
    padding: 16px;
    background: var(--copper);
    border: none;
    color: var(--charcoal);
    font-family: var(--font-body);
    font-size: 11px; font-weight: 500; letter-spacing: 0.2em; text-transform: uppercase;
    cursor: pointer;
    transition: background 0.3s;
    margin-top: 8px;
  }
  .form-submit:hover { background: var(--copper-light); }

  /* ── FOOTER ── */
  footer {
    background: #111;
    padding: 60px 48px 32px;
    border-top: 1px solid var(--border);
  }
  .footer-top {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 48px;
    margin-bottom: 48px;
  }
  .footer-logo {
    font-family: var(--font-display);
    font-size: 26px; font-weight: 400; letter-spacing: 0.04em;
    color: var(--off-white); margin-bottom: 16px;
  }
  .footer-logo span { color: var(--copper); }
  .footer-desc { font-size: 12px; font-weight: 300; line-height: 1.8; color: var(--text-muted); }
  .footer-col-title {
    font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--copper); margin-bottom: 20px;
  }
  .footer-links { list-style: none; display: flex; flex-direction: column; gap: 10px; }
  .footer-links a {
    font-size: 12px; font-weight: 300;
    color: var(--text-muted); text-decoration: none; transition: color 0.2s;
  }
  .footer-links a:hover { color: var(--copper-light); }
  .footer-bottom {
    display: flex; justify-content: space-between; align-items: center;
    padding-top: 28px; border-top: 1px solid var(--border);
    font-size: 11px; color: var(--text-muted); font-weight: 300;
  }
  .footer-bottom a { color: var(--copper); text-decoration: none; }

  /* ── SCROLL REVEAL ── */
  .reveal {
    opacity: 0; transform: translateY(30px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }
  .reveal.visible { opacity: 1; transform: none; }

  /* ── LANGUAGE PANEL ── */
  .lang-content { display: none; }
  .lang-content.active { display: block; }
</style>
</head>
<body>

<!-- NAVIGATION -->
<nav id="navbar">
  <a class="nav-logo" href="#hero">Aura <span>Estates</span></a>
  <div class="nav-links">
    <a href="#properties">Properties</a>
